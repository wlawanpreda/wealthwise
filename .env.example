# ============================================================================
# Wealthwise — Environment Variables
# ============================================================================
# Copy this to .env.local and fill in values.
# NEVER commit .env.local. Cloud Run uses Secret Manager for production values.
# ============================================================================

# ----------------------------------------------------------------------------
# Public Firebase Web SDK (safe to expose, but restrict the API key in GCP)
# https://console.cloud.google.com/apis/credentials → restrict by HTTP referrer
# ----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=epj-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=epj-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=epj-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_ID=ai-studio-90135de2-3486-4320-b16e-586197ead7d3

# ----------------------------------------------------------------------------
# Server-only — Firebase Admin SDK (NEVER expose to client)
# In Cloud Run: mount via Secret Manager, NOT as plain env var.
# Local dev: paste the JSON service account key contents on a single line.
# ----------------------------------------------------------------------------
FIREBASE_ADMIN_SERVICE_ACCOUNT=

# Cross-database aggregation (server-only reads via Admin SDK)
RETIRE_TAX_DB_ID=ai-studio-dd59df49-bdc8-4a37-b1db-474d9eb6670d
RETIRE_5_PERCENT_DB_ID=ai-studio-f28f242a-7cd7-4595-a85a-ecaf6d132941

# ----------------------------------------------------------------------------
# Server-only — Gemini AI (NEVER expose to client)
# ----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ----------------------------------------------------------------------------
# Session
# ----------------------------------------------------------------------------
SESSION_COOKIE_NAME=__wealthwise_session
SESSION_MAX_AGE_SECONDS=432000

# ----------------------------------------------------------------------------
# App URL (used for OAuth redirect, absolute URLs in server actions)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
