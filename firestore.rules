rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function verified() {
      return request.auth.token.email_verified == true;
    }

    function isValidFinancialPlan(data) {
      return data.keys().hasAll(['income', 'allocations', 'liabilities', 'emergencyFunds'])
        && data.income is number && data.income >= 0
        && data.allocations is list && data.allocations.size() <= 100
        && data.liabilities is list && data.liabilities.size() <= 50
        && data.emergencyFunds is list && data.emergencyFunds.size() <= 20;
    }

    match /users/{userId} {
      match /plan/current {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && verified() && isValidFinancialPlan(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
