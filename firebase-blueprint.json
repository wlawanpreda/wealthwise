{
  "entities": {
    "BudgetAllocation": {
      "title": "Budget Allocation",
      "description": "Allocation of income to a specific category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string", "enum": ["Constant", "Spending", "Reserve"] }
      },
      "required": ["id", "name", "amount", "category"]
    },
    "Liability": {
      "title": "Liability",
      "description": "A debt or financial obligation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "totalAmount": { "type": "number" },
        "monthlyPayment": { "type": "number" },
        "dueDate": { "type": "string" }
      },
      "required": ["id", "name", "totalAmount", "monthlyPayment"]
    },
    "FinancialAccount": {
      "title": "Financial Account",
      "description": "Liquidity reserve or investment account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "purpose": { "type": "string" },
        "isEmergencyFund": { "type": "boolean" },
        "type": { "type": "string", "enum": ["Savings", "Fixed", "Investment", "Other"] },
        "transactions": {
          "type": "array",
          "items": { "$ref": "#/entities/Transaction" }
        }
      },
      "required": ["id", "name", "amount", "purpose", "isEmergencyFund", "transactions"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A deposit or withdrawal related to an account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal"] },
        "amount": { "type": "number" },
        "note": { "type": "string" }
      },
      "required": ["id", "timestamp", "type", "amount"]
    },
    "FinancialSnapshot": {
      "title": "Financial Snapshot",
      "description": "Historical record of financial status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "month": { "type": "string" },
        "timestamp": { "type": "number" },
        "totalWealth": { "type": "number" },
        "totalDebt": { "type": "number" },
        "netWorth": { "type": "number" },
        "savingsRate": { "type": "number" }
      },
      "required": ["id", "month", "timestamp", "totalWealth", "totalDebt", "netWorth", "savingsRate"]
    },
    "IncomeProjection": {
      "title": "Income Projection",
      "description": "Planned changes in income",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "monthlyAmountChange": { "type": "number" },
        "startDate": { "type": "string" },
        "type": { "type": "string", "enum": ["increase", "decrease"] }
      },
      "required": ["id", "name", "monthlyAmountChange", "startDate", "type"]
    },
    "FinancialPlan": {
      "title": "Financial Plan",
      "description": "A user's complete financial state",
      "type": "object",
      "properties": {
        "income": { "type": "number" },
        "savingsTarget": { "type": "number" },
        "allocations": { 
          "type": "array",
          "items": { "$ref": "#/entities/BudgetAllocation" }
        },
        "liabilities": { 
          "type": "array",
          "items": { "$ref": "#/entities/Liability" }
        },
        "emergencyFunds": { 
          "type": "array",
          "items": { "$ref": "#/entities/FinancialAccount" }
        },
        "history": {
          "type": "array",
          "items": { "$ref": "#/entities/FinancialSnapshot" }
        },
        "projections": {
          "type": "array",
          "items": { "$ref": "#/entities/IncomeProjection" }
        }
      },
      "required": ["income", "allocations", "liabilities", "emergencyFunds"]
    }
  },
  "firestore": {
    "/users/{userId}/plan/current": {
      "schema": "FinancialPlan",
      "description": "The current financial plan for the user"
    }
  }
}
