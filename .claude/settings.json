{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install --lockfile-only)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(pnpm add:*)",
      "Bash(pnpm clean)",
      "Bash(pnpm clean:all)",
      "Bash(pnpm fix:case)",
      "Bash(pnpm dev)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build)",
      "Bash(pnpm start)",
      "Bash(pnpm start:*)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm format)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm test)",
      "Bash(pnpm test:watch)",
      "Bash(pnpm test:e2e)",
      "Bash(pnpm docker:build)",
      "Bash(pnpm docker:run)",
      "Bash(pnpm docker:up)",
      "Bash(pnpm docker:down)",
      "Bash(pnpm docker:logs)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpm vitest:*)",
      "Bash(corepack enable)",
      "Bash(corepack prepare:*)",

      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",

      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",

      "Bash(node --version)",
      "Bash(pnpm --version)",
      "Bash(docker --version)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout -B:*)",
      "Bash(git branch -D:*)",
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(docker:*)",
      "Bash(gcloud:*)",
      "Bash(firebase:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(npx:*)",
      "Bash(npm:*)",
      "Bash(yarn:*)"
    ]
  }
}
